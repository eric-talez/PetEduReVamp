                </div>
              </CardContent>
              <CardFooter className="flex flex-col gap-3">
                {hasReserved ? (
                  <>
                    <div className="w-full bg-green-50 dark:bg-green-900/20 p-3 rounded-md mb-2 text-center">
                      <CheckCircle className="h-6 w-6 mx-auto mb-2 text-green-600 dark:text-green-500" />
                      <p className="font-medium text-green-800 dark:text-green-300">예약이 완료되었습니다</p>
                      <p className="text-sm text-green-700 dark:text-green-400">
                        {selectedSlot ? `${selectedSlot.date} ${selectedSlot.time}` : ''}
                      </p>
                    </div>
                    <Button 
                      className="w-full flex items-center justify-center" 
                      onClick={openZoomMeeting}
                    >
                      <Video className="mr-2 h-4 w-4" />
                      Zoom으로 수업 참여하기
                    </Button>
                  </>
                ) : (
                  <Button 
                    className="w-full" 
                    onClick={handleReservation}
                    disabled={!selectedSlot}
                  >
                    {selectedSlot ? '예약하기' : '일정을 선택해주세요'}
                  </Button>
                )}
                
                <Button variant="outline" className="w-full" asChild>
                  <Link href="/video-call">
                    다른 수업 보기
                  </Link>
                </Button>
              </CardFooter>
            </Card>
          </div>
        </div>
      )}
    </div>
  );
}