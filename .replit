modules = ["nodejs-20", "web", "openjdk-17", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["maven", "openjdk17", "unzip", "imagemagick"]

[deployment]
deploymentTarget = "gce"
build = [
  "sh",
  "-c",
  "npm run build && rm -rf server/public && cp -r dist/public server/public",
]
run = ["sh", "-c", "npm start"]

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Production Build"
author = 37268622
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node optimize-production.js"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run build"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "NODE_ENV=production node production-start.js"

[[workflows.workflow]]
name = "Check and Fix"
author = 37268622
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node scripts/check-missing-endpoints.js"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"

[languages.typescript]
pattern = "**/{*.ts,*.tsx}"
syntax = "typescript"

[languages.typescript.languageServer]
start = ["typescript-language-server", "--stdio"]

[agent]
integrations = [
  "javascript_stripe:1.0.0",
  "perplexity_v0:1.0.0",
  "javascript_object_storage:1.0.0",
  "javascript_openai:1.0.0",
  "javascript_gemini:1.0.0",
]

[userenv]

[userenv.shared]
GOOGLE_CSE_ID = "f343e762f44de42db"
GOOGLE_CUSTOM_SEARCH_ENGINE_ID = "f343e762f44de42db"
VITE_SHOP_URL = "https://store.funnytalez.com/"
