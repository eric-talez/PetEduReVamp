modules = ["nodejs-20", "web", "postgresql-16", "openjdk-17"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["maven", "openjdk17", "unzip"]

[deployment]
deploymentTarget = "autoscale"
build = ["sh", "-c", "npm run build && rm -rf server/public && cp -r dist/public server/public"]
run = ["npm", "run", "start"]

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 33855
externalPort = 3002

[[ports]]
localPort = 35393
externalPort = 8081

[[ports]]
localPort = 37461
externalPort = 8080

[[ports]]
localPort = 39195
externalPort = 4200

[[ports]]
localPort = 39593
externalPort = 6800

[[ports]]
localPort = 39611
externalPort = 8000

[[ports]]
localPort = 41399
externalPort = 3000

[[ports]]
localPort = 41565
externalPort = 5173

[[ports]]
localPort = 44559
externalPort = 8008

[[ports]]
localPort = 45787
externalPort = 3003

[[ports]]
localPort = 46075
externalPort = 6000

[[ports]]
localPort = 46529
externalPort = 5000

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Production Build"
author = 37268622
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node optimize-production.js"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run build"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "NODE_ENV=production node production-start.js"

[[workflows.workflow]]
name = "Check and Fix"
author = 37268622
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node scripts/check-missing-endpoints.js"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"

[languages.typescript]
pattern = "**/{*.ts,*.tsx}"
syntax = "typescript"

[languages.typescript.languageServer]
start = ["typescript-language-server", "--stdio"]

[agent]
integrations = ["javascript_stripe:1.0.0", "perplexity_v0:1.0.0", "javascript_object_storage:1.0.0", "javascript_openai:1.0.0", "javascript_gemini:1.0.0"]
