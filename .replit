modules = ["nodejs-20", "web", "postgresql-16", "openjdk-17"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["maven", "openjdk17", "unzip", "jq"]

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
run = ["npm", "run", "start"]

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 33855
externalPort = 3002

[[ports]]
localPort = 41399
externalPort = 3000

[[ports]]
localPort = 41495
externalPort = 3003

[[ports]]
localPort = 45371
externalPort = 5173

[[ports]]
localPort = 46501
externalPort = 4200

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Production Build"
author = 37268622
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node optimize-production.js"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run build"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "NODE_ENV=production node production-start.js"

[[workflows.workflow]]
name = "Check and Fix"
author = 37268622
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node scripts/check-missing-endpoints.js"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"

[languages.typescript]
pattern = "**/{*.ts,*.tsx}"
syntax = "typescript"

[languages.typescript.languageServer]
start = ["typescript-language-server", "--stdio"]

[agent]
integrations = ["javascript_stripe:1.0.0", "perplexity_v0:1.0.0"]
