# TALEZ 운영 환경 설정

# =================================
# 기본 환경 설정
# =================================
NODE_ENV=production
PORT=5000
HOST=0.0.0.0

# =================================
# 데이터베이스 설정
# =================================
# PostgreSQL (필수)
DATABASE_URL=postgresql://username:password@localhost:5432/talez_production

# =================================
# 보안 설정
# =================================
# 세션 비밀키 (강력한 랜덤 문자열로 교체 필요)
SESSION_SECRET=your-super-secure-session-secret-here-production

# JWT 비밀키
JWT_SECRET=your-jwt-secret-key-here

# 암호화 키
ENCRYPTION_KEY=your-32-character-encryption-key

# =================================
# 외부 서비스 API 키
# =================================
# Stripe 결제 (필수)
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# OpenAI API (AI 기능용)
OPENAI_API_KEY=sk-your-openai-api-key

# Google Gemini API
GOOGLE_AI_API_KEY=your-google-ai-api-key

# SendGrid 이메일 서비스 (필수)
SENDGRID_API_KEY=SG.your-sendgrid-api-key

# =================================
# 소셜 로그인 설정
# =================================
# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# 카카오 OAuth
KAKAO_CLIENT_ID=your-kakao-app-key
KAKAO_CLIENT_SECRET=your-kakao-client-secret

# 네이버 OAuth
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# =================================
# 지도 서비스
# =================================
# 네이버 지도 API
NAVER_MAP_CLIENT_ID=your-naver-map-client-id
NAVER_MAP_CLIENT_SECRET=your-naver-map-client-secret

# 카카오 지도 API
KAKAO_MAP_API_KEY=your-kakao-map-api-key

# =================================
# 모니터링 및 로깅
# =================================
# Sentry (에러 트래킹)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# =================================
# 파일 업로드 및 CDN
# =================================
# AWS S3 (파일 저장소)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-northeast-2
AWS_BUCKET_NAME=talez-production

# CloudFlare (CDN)
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ZONE_ID=your-zone-id

# =================================
# 도메인 및 CORS 설정
# =================================
# 프론트엔드 도메인
FRONTEND_URL=https://www.talez.co.kr
CORS_ORIGIN=https://www.talez.co.kr

# API 도메인
API_BASE_URL=https://api.talez.co.kr

# =================================
# 캐시 설정
# =================================
# Redis (세션 저장소 및 캐시)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your-redis-password

# =================================
# 알림 서비스
# =================================
# Firebase Cloud Messaging (푸시 알림)
FCM_SERVER_KEY=your-fcm-server-key
FCM_PROJECT_ID=your-firebase-project-id

# VAPID 키 (웹 푸시)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=admin@talez.co.kr

# =================================
# 분석 및 마케팅
# =================================
# Google Analytics
GA_TRACKING_ID=G-your-ga-tracking-id

# Facebook Pixel
FACEBOOK_PIXEL_ID=your-facebook-pixel-id

# =================================
# 기타 설정
# =================================
# 로그 레벨 (error, warn, info, debug)
LOG_LEVEL=warn

# 최대 파일 업로드 크기 (MB)
MAX_FILE_SIZE=10

# 세션 만료 시간 (밀리초)
SESSION_TIMEOUT=3600000

# API 레이트 리미팅 (요청/분)
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60000

# =================================
# 보안 헤더 설정
# =================================
# 허용된 도메인 목록
ALLOWED_ORIGINS=https://www.talez.co.kr,https://admin.talez.co.kr

# Content Security Policy
CSP_REPORT_URI=https://api.talez.co.kr/csp-report