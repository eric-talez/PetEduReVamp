
# =================================
# 🚀 TALEZ 프로덕션 환경 설정
# =================================

# 기본 서버 설정
NODE_ENV=production
PORT=5000
HOST=0.0.0.0

# 데이터베이스 설정 (필수)
DATABASE_URL=postgresql://username:password@localhost:5432/talez_production

# 보안 설정 (필수 - 반드시 변경)
SESSION_SECRET=your-super-secure-session-secret-at-least-32-characters-long
CORS_ORIGIN=https://your-domain.com
ENCRYPTION_KEY=your-32-character-encryption-key

# API 키들 (선택사항)
OPENAI_API_KEY=sk-your-openai-api-key
KAKAO_MAPS_API_KEY=your-kakao-maps-api-key
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# 소셜 로그인 설정
KAKAO_CLIENT_ID=your-kakao-client-id
KAKAO_CLIENT_SECRET=your-kakao-client-secret
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Rate Limiting 설정
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_MS=900000

# 로깅 설정
LOG_LEVEL=warn
LOG_FILE_PATH=./logs/application.log
ERROR_LOG_PATH=./logs/error.log

# SSL/HTTPS 설정
SSL_ENABLED=true
SSL_KEY_PATH=/path/to/ssl/private.key
SSL_CERT_PATH=/path/to/ssl/certificate.crt

# 파일 업로드 설정
MAX_UPLOAD_SIZE_MB=10
UPLOAD_PATH=./public/uploads
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx

# CDN 및 이미지 최적화
CDN_URL=https://cdn.your-domain.com
IMAGE_OPTIMIZATION_ENABLED=true
IMAGE_QUALITY=80

# 이메일 설정
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_USER=your-email@domain.com
SMTP_PASS=your-email-password
FROM_EMAIL=noreply@your-domain.com

# SMS 설정 (선택사항)
SMS_API_KEY=your-sms-api-key
SMS_SENDER=TALEZ

# 결제 설정
PAYMENT_GATEWAY=stripe
STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# 모니터링 설정
MONITORING_ENABLED=true
METRICS_ENDPOINT=/api/monitoring/metrics
HEALTH_CHECK_ENDPOINT=/health

# 캐싱 설정
REDIS_URL=redis://localhost:6379
CACHE_TTL_MINUTES=30
SESSION_STORE=redis

# 데이터베이스 최적화
DB_POOL_SIZE=10
DB_CONNECTION_TIMEOUT=30000
DB_IDLE_TIMEOUT=30000

# 보안 헤더 설정
SECURITY_HEADERS_ENABLED=true
HSTS_MAX_AGE=31536000
CSP_ENABLED=true

# 백업 설정
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=./backups

# 분석 및 추적
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX
FACEBOOK_PIXEL_ID=your-facebook-pixel-id

# =================================
# 개발 환경 전용 설정
# =================================
# (프로덕션에서는 제거)
DEBUG_MODE=false
MOCK_EXTERNAL_APIS=false
SEED_DATABASE=false
